# WebReconAgent 环境变量配置
# 复制此文件为 .env 并填写对应值
#
# 命令行参数 --api-key / --base-url 优先级高于此文件

# ── Anthropic 官方 API Key ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── 第三方中转站 / OpenRouter ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=<中转站Key>
# ANTHROPIC_BASE_URL=https://your-proxy.com/v1

# ── OpenRouter ──────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-or-xxxxxxxx
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# ── ChatGPT / OpenAI（需先启动 LiteLLM：litellm --model gpt-4o --port 4000）
# ANTHROPIC_API_KEY=sk-xxxxxxxx
# ANTHROPIC_BASE_URL=http://localhost:4000
